#!/bin/bash

# Check if .tool-versions exists in the current directory
if [ ! -f .tool-versions ]; then
  echo "❌ Error: No .tool-versions file found in the current working directory."
  exit 1
fi

# List of core built-in proto tools that do not require an external plugin loader
BUILT_INS="node python poetry go rust bun deno pnpm yarn uv ruby moon"

echo "🔄 Syncing .tool-versions to .prototools..."

# Read .tool-versions line by line
while read -r tool version || [ -n "$tool" ]; do
  # Skip empty lines, lines with just whitespace, or lines starting with '#'
  [[ -z "$tool" || "$tool" =~ ^[[:space:]]*$ || "$tool" =~ ^# ]] && continue

  # Clean whitespace and extract only the first version if multiple are provided
  tool=$(echo "$tool" | awk '{print $1}')
  version=$(echo "$version" | awk '{print $1}')

  # Fix name translation: convert ASDF's 'nodejs' to proto's native 'node'
  if [ "$tool" = "nodejs" ]; then
    tool="node"
  fi

  # -------------------------------------------------------------------------
  # RESILIENT EXECUTION BLOCK
  # Using a subshell container to trap and isolate tool-specific failures
  # -------------------------------------------------------------------------
  (
    # Re-enable exit-on-error *only* inside this subshell so a failure here
    # jumps straight to the local error handler instead of running the remaining subshell lines.
    set -e

    if [[ $BUILT_INS =~ (^|[[:space:]])$tool($|[[:space:]]) ]]; then
      echo "  -> Pinning native built-in: $tool to $version"
      proto pin "$tool" "$version"
    else
      echo "  -> Mapping & pinning custom tool via built-in ASDF backend: $tool to $version"

      # Pin using the asdf: identifier
      proto pin "asdf:$tool" "$version"

      # Specific override for adr-tools shim naming
      if [ "$tool" = "adr-tools" ] && ! grep -q "\[tools\.\"asdf:$tool\"\]" .prototools; then
        echo -e "\n[tools.\"asdf:$tool\"]\nexes = [\"adr\"]" >> .prototools
      fi

      echo "     Installing tool environment..."
      proto install "asdf:$tool" --yes

      # Dynamic Symlink Patch for structural variances
      TARGET_DIR="$HOME/.proto/tools/$tool/$version"
      if [ -d "$TARGET_DIR" ] && [ ! -f "$TARGET_DIR/$tool" ]; then
        SHORT_NAME=$(echo "$tool" | sed 's/-tools//' | sed 's/cli//')
        REAL_BIN=$(find "$TARGET_DIR" -type f -name "$SHORT_NAME" -perm -u+x | head -n 1)

        if [ -n "$REAL_BIN" ]; then
          echo "     🔗 Linking nested binary to root: $(basename "$REAL_BIN") -> $tool"
          ln -sf "$REAL_BIN" "$TARGET_DIR/$tool"
        fi
      fi
    fi
  ) || {
    # This block executes ONLY if the subshell above hits a failure command
    echo "⚠️  Warning: Processing failed for tool '$tool'. Skipping to next tool..."
  }
  # -------------------------------------------------------------------------

done < .tool-versions

echo "✅ Done! Completed scanning and processing all toolchains."